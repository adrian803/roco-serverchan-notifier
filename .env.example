# 运行模式：
# auto      配置齐 ROCOM_API_KEY + 任一推送通道 Key 后自动托管，不启动 Web UI；缺配置时启动控制台
# web       强制启动控制台
# scheduler 只按环境变量/配置文件定时推送，不启动 Web UI
APP_MODE=auto

# 可选：作为首次启动默认值；之后可在 Web 控制台修改
ROCOM_API_KEY=

# 可选：自定义 WeGame 数据接口；通常保持空即可。
# 默认接口使用上游缓存；如确需绕过缓存，可自行设为带 ?refresh=true 的地址。
ROCOM_API_URL=

# 可选：作为首次启动默认值；之后可在 Web 控制台修改
SERVERCHAN_SENDKEY=

# 无控制台托管模式可任选一种通道，只填该通道需要的 key
# PUSHPLUS_TOKEN=
# PUSHPLUS_TOPIC=
# PUSHPLUS_CHANNEL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK=
# WECOM_BOT_KEY=
# WECOM_BOT_WEBHOOK=
# WECOM_CORPID=
# WECOM_SECRET=
# WECOM_AGENTID=
# WECOM_TOUSER=@all
# WXPUSHER_APP_TOKEN=
# WXPUSHER_UIDS=
# WXPUSHER_TOPIC_IDS=
# BARK_DEVICE_KEY=
# BARK_SERVER_URL=https://api.day.app
# DINGTALK_WEBHOOK=
# DINGTALK_SECRET=
# FEISHU_WEBHOOK=
# FEISHU_SECRET=
# NTFY_TOPIC=
# NTFY_BASE_URL=https://ntfy.sh
# GOTIFY_BASE_URL=
# GOTIFY_APP_TOKEN=

# 可选：没有商品时是否也推送
NOTIFY_EMPTY=false

# 可选：推送商品时附带限购数量、单价和合计洛克贝；未收录价格显示“价格未收录”
INCLUDE_PRICE_INFO=false

# 可选：首次启动默认发送策略 all / single / failover
DELIVERY_MODE=all

# 可选：HTTP 超时秒数
HTTP_TIMEOUT=30

# Docker 常驻调度使用：北京时间执行时间，逗号分隔；默认刷新后 5 分钟推送
SCHEDULE_TIMES=08:05,12:05,16:05,20:05

# Docker 常驻调度使用：容器启动后是否立即执行一次
RUN_ON_START=false

# Web 控制台
WEB_PORT=19892
DOCKER_IMAGE=linxi5013/roco-serverchan-notifier:latest
CONSOLE_USERNAME=admin
# 留空时首次启动会生成强密码，明文打印到日志，哈希保存到 ./data/config.json。
CONSOLE_PASSWORD=
# 仅可信本机环境临时调试时才设为 true，显式关闭控制台认证。
CONSOLE_ALLOW_EMPTY_PASSWORD=false
